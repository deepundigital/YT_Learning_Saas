const axios = require("axios");

const OPENROUTER_API_URL = "https://openrouter.ai/api/v1/chat/completions";
const OPENROUTER_API_KEY = process.env.OPENROUTER_API_KEY;
const OPENROUTER_MODEL =
  process.env.OPENROUTER_MODEL || "deepseek/deepseek-chat-v3-0324:free";

function buildBrandSignature() {
  return "\n\n✨ Generated by Interactive Lea AI";
}

async function callOpenRouter(messages, temperature = 0.4) {
  if (!OPENROUTER_API_KEY) {
    throw new Error("OPENROUTER_API_KEY is missing in .env");
  }

  const response = await axios.post(
    OPENROUTER_API_URL,
    {
      model: OPENROUTER_MODEL,
      messages,
      temperature,
    },
    {
      headers: {
        Authorization: `Bearer ${OPENROUTER_API_KEY}`,
        "Content-Type": "application/json",
        "HTTP-Referer": "http://localhost:5000",
        "X-Title": "Interactive Lea Backend",
      },
      timeout: 60000,
    }
  );

  const content = response?.data?.choices?.[0]?.message?.content?.trim();

  if (!content) {
    throw new Error("No AI response received");
  }

  return content;
}

async function generateSummary({ title, description, transcriptText }) {
  const hasTranscript = !!transcriptText?.trim();

  const systemPrompt = `
You are a smart AI tutor for a coding-focused interactive learning platform.
Write a concise, useful, student-friendly summary.
Keep it clear and structured.
Do not hallucinate.
`.trim();

  const userPrompt = hasTranscript
    ? `
Create a learning summary from this YouTube video transcript.

Title: ${title || "Untitled"}
Description: ${description || "No description"}

Transcript:
${transcriptText}

Instructions:
- Write in simple English
- Cover key ideas
- Keep it concise but useful
- 3 to 6 short paragraphs
`.trim()
    : `
Create a learning summary from the available YouTube metadata.

Title: ${title || "Untitled"}
Description: ${description || "No description"}

Instructions:
- Mention that this is based on metadata only
- Keep it concise
- Do not invent transcript details
`.trim();

  const content = await callOpenRouter(
    [
      { role: "system", content: systemPrompt },
      { role: "user", content: userPrompt },
    ],
    0.4
  );

  return content + buildBrandSignature();
}

async function generateFlashcards({
  title,
  description,
  transcriptText,
  count = 8,
}) {
  const hasTranscript = !!transcriptText?.trim();

  const systemPrompt = `
You are an AI study assistant.
Generate flashcards for students.
Return ONLY valid JSON array.
Each item must be:
{ "question": "...", "answer": "..." }
`.trim();

  const userPrompt = hasTranscript
    ? `
Generate ${count} flashcards from this video transcript.

Title: ${title || "Untitled"}
Description: ${description || "No description"}

Transcript:
${transcriptText}
`.trim()
    : `
Generate ${count} flashcards from this video metadata only.

Title: ${title || "Untitled"}
Description: ${description || "No description"}

Do not invent details beyond metadata.
`.trim();

  const content = await callOpenRouter(
    [
      { role: "system", content: systemPrompt },
      { role: "user", content: userPrompt },
    ],
    0.3
  );

  let parsed;
  try {
    parsed = JSON.parse(content);
  } catch (error) {
    const match = content.match(/\[[\s\S]*\]/);
    if (!match) {
      throw new Error("AI did not return valid flashcards JSON");
    }
    parsed = JSON.parse(match[0]);
  }

  if (!Array.isArray(parsed)) {
    throw new Error("Flashcards response is not an array");
  }

  return parsed
    .filter((item) => item?.question && item?.answer)
    .map((item) => ({
      question: String(item.question).trim(),
      answer: String(item.answer).trim(),
    }));
}

module.exports = {
  generateSummary,
  generateFlashcards,
};